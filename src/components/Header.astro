---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { SITE_NAME } from '../consts';

const whatsappUrl =
	'https://wa.me/5527997441969?text=' +
	encodeURIComponent(
		'Olá, Vim do seu site, vi seu anúncio e gostaria de saber mais informações sobre os notebooks seminovos.',
	);

const navItems = [
	{ href: '/blog', label: 'Blog' },
	{ href: '#beneficios', label: 'Benefícios' },
	{ href: '#sobre', label: 'Sobre nós' },
	{ href: '#depoimentos', label: 'Depoimentos' },
	{ href: '#faq', label: 'Dúvidas' },
];
---

<header class="sticky top-0 z-50 border-b border-slate-100 bg-background/95 backdrop-blur-sm">
	<div class="container-site flex items-center justify-between gap-4 py-4">
		<a href="/" aria-label={`${SITE_NAME} — página inicial`}>
			<Image
				src={logo}
				alt={`Logo ${SITE_NAME}`}
				width={300}
				height={120}
				format="webp"
				quality="mid"
				loading="eager"
				class="site-logo"
			/>
		</a>

		<div class="header-menu flex items-center gap-4">
			<input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />
			<label for="nav-toggle" class="nav-hamburger" aria-label="Abrir menu de navegação">
				<span></span>
				<span></span>
				<span></span>
			</label>

			<nav class="nav-panel" aria-label="Navegação principal">
				<ul class="nav-list">
					{
						navItems.map((item) => (
							<li>
								<a href={item.href}>{item.label}</a>
							</li>
						))
					}
				</ul>
				<a
					class="btn-primary nav-cta-mobile"
					href={whatsappUrl}
					target="_blank"
					rel="noopener noreferrer"
				>
					Fale no WhatsApp
				</a>
			</nav>
		</div>

		<a
			class="btn-primary header-cta-desktop"
			href={whatsappUrl}
			target="_blank"
			rel="noopener noreferrer"
		>
			Fale no WhatsApp
		</a>
	</div>
</header>

<style>
	.site-logo {
		width: 200px;
		height: auto;
	}

	.nav-toggle {
		position: absolute;
		opacity: 0;
		width: 0;
		height: 0;
		pointer-events: none;
	}

	.nav-hamburger {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 2.5rem;
		height: 2.5rem;
		cursor: pointer;
	}

	.nav-hamburger span {
		display: block;
		height: 2px;
		width: 100%;
		background-color: var(--color-text);
		border-radius: 999px;
		transition: transform 0.2s ease, opacity 0.2s ease;
	}

	.nav-panel {
		display: none;
	}

	.nav-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.nav-list a {
		color: var(--color-text);
		text-decoration: none;
		font-weight: 600;
	}

	.nav-list a:hover {
		color: var(--color-accent);
	}

	.header-cta-desktop {
		display: none;
	}

	.nav-cta-mobile {
		margin-top: 0.5rem;
		width: 100%;
	}

	.nav-toggle:checked ~ .nav-panel {
		display: flex;
		flex-direction: column;
		position: absolute;
		top: 100%;
		right: 0;
		left: 0;
		background: var(--color-background);
		border-bottom: 1px solid #e2e8f0;
		padding: 1.25rem 1rem 1.5rem;
		box-shadow: 0 12px 24px rgb(16 33 104 / 8%);
	}

	.header-menu {
		position: relative;
	}

	@media (min-width: 768px) {
		.nav-hamburger {
			display: none;
		}

		.nav-panel {
			display: flex;
			align-items: center;
			position: static;
			background: transparent;
			border: 0;
			padding: 0;
			box-shadow: none;
		}

		.nav-list {
			flex-direction: row;
			gap: 1.5rem;
		}

		.nav-cta-mobile {
			display: none;
		}

		.header-cta-desktop {
			display: inline-flex;
		}
	}
</style>
