---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { SITE_NAME } from '../consts';
import whatsappIcon from '../assets/icons/whatsapp.svg?raw';

const whatsappUrl =
	'https://wa.me/5527997441969?text=' +
	encodeURIComponent(
		'Olá! Gostaria de mais informações sobre os notebooks seminovos.',
	);

const navItems = [
	{ href: '/blog', label: 'Blog', mobile: false },
	{ href: '/onde-atendemos', label: 'Onde Atendemos', mobile: true },
	{ href: '#beneficios', label: 'Benefícios', mobile: true },
	{ href: '#sobre', label: 'Sobre nós', mobile: true },
	{ href: '#depoimentos', label: 'Depoimentos', mobile: true },
	{ href: '#faq', label: 'Dúvidas', mobile: true },
];
---

<header class="site-header">
	<input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true" />

	<div class="container-site header-inner">
		<a class="header-logo" href="/" aria-label={`${SITE_NAME} — página inicial`}>
			<Image
				src={logo}
				alt={`Logo ${SITE_NAME}`}
				width={300}
				height={120}
				format="webp"
				quality="mid"
				loading="eager"
				class="site-logo"
			/>
		</a>

		<a
			class="btn-primary header-cta-mobile"
			href={whatsappUrl}
			target="_blank"
			rel="noopener noreferrer"
		>
			Contato
			<span class="btn-icon" aria-hidden="true" set:html={whatsappIcon} />
		</a>

		<label for="nav-toggle" class="nav-hamburger" aria-label="Abrir menu de navegação">
			<span></span>
			<span></span>
			<span></span>
		</label>

		<a
			class="btn-primary header-cta-desktop"
			href={whatsappUrl}
			target="_blank"
			rel="noopener noreferrer"
		>
			Contato
		</a>

		<nav class="nav-panel nav-panel-desktop" aria-label="Navegação principal">
			<ul class="nav-list">
				{
					navItems.map((item) => (
						<li>
							<a href={item.href}>{item.label}</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>

	<nav class="nav-panel nav-panel-mobile" aria-label="Navegação principal">
		<ul class="nav-list">
			{
				navItems
					.filter((item) => item.mobile)
					.map((item) => (
						<li>
							<a href={item.href}>{item.label}</a>
						</li>
					))
			}
		</ul>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		border-bottom: 1px solid #e2e8f0;
		background: var(--color-background);
	}

	.header-inner {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 0.75rem;
		padding-block: 0.875rem;
	}

	.header-logo {
		grid-column: 1;
		justify-self: start;
		line-height: 0;
	}

	.site-logo {
		width: 8.75rem;
		height: auto;
	}

	.header-cta-mobile {
		grid-column: 2;
		justify-self: center;
		padding: 0.5rem 1rem;
		font-size: 0.875rem;
		white-space: nowrap;
	}

	.nav-hamburger {
		grid-column: 3;
		justify-self: end;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		width: 2.5rem;
		height: 2.5rem;
		cursor: pointer;
	}

	.btn-icon :global(svg) {
		display: block;
		width: 1rem;
		height: 1rem;
	}

	.btn-icon :global(svg title) {
		display: none;
	}

	.nav-toggle {
		position: absolute;
		opacity: 0;
		width: 0;
		height: 0;
		pointer-events: none;
	}

	.nav-hamburger span {
		display: block;
		height: 2.5px;
		width: 100%;
		background-color: #3d9be8;
		border-radius: 999px;
		transition: transform 0.2s ease, opacity 0.2s ease;
	}

	.nav-toggle:checked + .header-inner .nav-hamburger span:nth-child(1) {
		transform: translateY(7.5px) rotate(45deg);
	}

	.nav-toggle:checked + .header-inner .nav-hamburger span:nth-child(2) {
		opacity: 0;
	}

	.nav-toggle:checked + .header-inner .nav-hamburger span:nth-child(3) {
		transform: translateY(-7.5px) rotate(-45deg);
	}

	.nav-panel-mobile {
		display: none;
	}

	.nav-panel-desktop {
		display: none;
	}

	.nav-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.nav-list a {
		color: var(--color-text);
		text-decoration: none;
		font-weight: 600;
	}

	.nav-list a:hover {
		color: var(--color-accent-text);
	}

	.header-cta-desktop {
		display: none;
	}

	.nav-toggle:checked ~ .nav-panel-mobile {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding: 2rem 1rem 2.5rem;
		background: var(--color-background);
		border-bottom: 1px solid #e2e8f0;
		box-shadow: 0 12px 24px rgb(16 33 104 / 8%);
	}

	.nav-panel-mobile .nav-list {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.75rem;
	}

	.nav-panel-mobile .nav-list a {
		font-size: 1.125rem;
	}

	@media (min-width: 768px) {
		.header-inner {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding-block: 1rem;
		}

		.site-logo {
			width: 12.5rem;
		}

		.header-cta-mobile,
		.nav-hamburger,
		.nav-panel-mobile {
			display: none;
		}

		.nav-panel-desktop {
			display: flex;
			align-items: center;
			margin-left: auto;
			margin-right: 1rem;
		}

		.nav-panel-desktop .nav-list {
			display: flex;
			flex-direction: row;
			gap: 1.5rem;
		}

		.header-cta-desktop {
			display: inline-flex;
		}
	}
</style>
