---
import { getCollection } from 'astro:content';
import checkmarkCircle02 from '../assets/icons/checkmark-circle-02.svg?raw';
import invoice01 from '../assets/icons/invoice-01.svg?raw';
import deliveryTruck02 from '../assets/icons/delivery-truck-02.svg?raw';
import keyframesMultiple from '../assets/icons/keyframes-multiple.svg?raw';
import handHelping from '../assets/icons/hand-helping.svg?raw';
import leaf01 from '../assets/icons/leaf-01.svg?raw';

const benefitIcons: Record<string, string> = {
	'garantia-90-dias': checkmarkCircle02,
	'nota-fiscal': invoice01,
	'entrega-gratuita': deliveryTruck02,
	'ate-12x': keyframesMultiple,
	'pronta-entrega': handHelping,
	sustentabilidade: leaf01,
};

const benefits = (await getCollection('benefits')).sort((a, b) => a.data.order - b.data.order);
---

<section id="beneficios" class="section-benefits" aria-labelledby="benefits-title">
	<div class="container-site">
		<p class="section-eyebrow">Benefícios</p>
		<h2 id="benefits-title" class="section-title">Por Que Escolher Nossos Notebooks Seminovos?</h2>

		<div class="benefits-grid">
			{
				benefits.map((benefit) => (
					<article class="benefit-card">
						<div class="card-icon" aria-hidden="true" set:html={benefitIcons[benefit.id]} />
						<h3>{benefit.data.title}</h3>
						<p>{benefit.data.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.section-benefits {
		padding: 5rem 0;
		background: #f8fbff;
	}

	.benefits-grid {
		margin-top: 2.5rem;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
		gap: 1.25rem;
	}

	.benefit-card {
		padding: 1.5rem;
		border-radius: 1rem;
		border: 1px solid #e2e8f0;
		background: var(--color-background);
	}

	.card-icon {
		width: 32px;
		height: 32px;
		margin-bottom: 0.75rem;
		color: var(--color-accent-text);
	}

	.card-icon :global(svg) {
		display: block;
		width: 100%;
		height: 100%;
	}

	.benefit-card h3 {
		font-size: 1.125rem;
		margin-bottom: 0.5rem;
	}

	.benefit-card p {
		line-height: 1.6;
		color: color-mix(in srgb, var(--color-text) 80%, white);
	}
</style>
