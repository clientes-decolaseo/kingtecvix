<div
	id="cookie-consent"
	class="cookie-consent"
	role="dialog"
	aria-labelledby="cookie-consent-title"
	aria-describedby="cookie-consent-desc"
	aria-live="polite"
	hidden
>
	<div class="cookie-consent-inner container-site">
		<div class="cookie-consent-text">
			<p id="cookie-consent-title" class="cookie-consent-title">Cookies e privacidade</p>
			<p id="cookie-consent-desc" class="cookie-consent-desc">
				Usamos cookies de análise e publicidade para melhorar sua experiência. Consulte nossa
				<a href="/politica-privacidade">Política de Privacidade</a>.
			</p>
		</div>
		<div class="cookie-consent-actions">
			<button type="button" class="btn-primary cookie-btn-accept" data-action="accept">
				Aceitar
			</button>
			<button type="button" class="cookie-btn-reject" data-action="reject">Recusar</button>
		</div>
	</div>
</div>

<script is:inline>
	(function () {
		var STORAGE_KEY = 'cookie-consent';
		var banner = document.getElementById('cookie-consent');
		var floatingWhatsApp = document.getElementById('floating-whatsapp');

		function syncFloatingWhatsApp(isBannerVisible) {
			if (!floatingWhatsApp) return;
			floatingWhatsApp.classList.toggle('banner-visible', isBannerVisible);
		}

		function hideBanner() {
			if (banner) banner.hidden = true;
			syncFloatingWhatsApp(false);
		}

		function showBanner() {
			if (banner) banner.hidden = false;
			syncFloatingWhatsApp(true);
		}

		function scheduleGTM() {
			if (typeof window.loadGTM !== 'function') return;
			if ('requestIdleCallback' in window) {
				requestIdleCallback(window.loadGTM);
			} else {
				setTimeout(window.loadGTM, 2000);
			}
		}

		function saveConsent(value) {
			try {
				localStorage.setItem(STORAGE_KEY, value);
			} catch (e) {
				/* storage indisponível */
			}
		}

		function handleAccept() {
			saveConsent('accepted');
			hideBanner();
			scheduleGTM();
		}

		function handleReject() {
			saveConsent('rejected');
			hideBanner();
		}

		var consent = null;
		try {
			consent = localStorage.getItem(STORAGE_KEY);
		} catch (e) {
			consent = null;
		}

		if (consent === 'accepted') {
			hideBanner();
			scheduleGTM();
		} else if (consent === 'rejected') {
			hideBanner();
		} else {
			showBanner();
		}

		if (banner) {
			banner.addEventListener('click', function (event) {
				var target = event.target;
				if (!(target instanceof HTMLElement)) return;

				var action = target.getAttribute('data-action');
				if (action === 'accept') handleAccept();
				if (action === 'reject') handleReject();
			});
		}
	})();
</script>

<style>
	.cookie-consent {
		position: fixed;
		inset-inline: 0;
		bottom: 0;
		z-index: 100;
		padding: 1rem;
		background: var(--color-background);
		border-top: 1px solid #e2e8f0;
		box-shadow: 0 -8px 24px rgb(16 33 104 / 10%);
	}

	.cookie-consent[hidden] {
		display: none;
	}

	.cookie-consent-inner {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: flex-start;
	}

	.cookie-consent-title {
		margin: 0 0 0.25rem;
		font-size: 1rem;
		font-weight: 600;
		color: var(--color-text);
	}

	.cookie-consent-desc {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.5;
		color: color-mix(in srgb, var(--color-text) 85%, white);
	}

	.cookie-consent-desc a {
		color: var(--color-text);
		font-weight: 600;
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.cookie-consent-desc a:hover {
		color: var(--color-accent);
	}

	.cookie-consent-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		width: 100%;
	}

	.cookie-btn-accept {
		font-size: 0.9rem;
		padding: 0.65rem 1.25rem;
	}

	.cookie-btn-reject {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1.25rem;
		border: 2px solid var(--color-text);
		border-radius: var(--radius-button);
		background: transparent;
		color: var(--color-text);
		font-family: var(--font-sans);
		font-size: 0.9rem;
		font-weight: 600;
		cursor: pointer;
		transition: background-color 0.2s ease, color 0.2s ease;
	}

	.cookie-btn-reject:hover {
		background: color-mix(in srgb, var(--color-text) 8%, white);
	}

	@media (min-width: 768px) {
		.cookie-consent-inner {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
		}

		.cookie-consent-actions {
			width: auto;
			flex-shrink: 0;
		}
	}
</style>
