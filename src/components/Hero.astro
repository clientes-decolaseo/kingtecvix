---
import HeroVideoFacade from './HeroVideoFacade.astro';
import whatsappIcon from '../assets/icons/whatsapp.svg?raw';

const heroWhatsappUrl =
	'https://wa.me/5527997441969?text=' +
	encodeURIComponent(
		'Olá! Quero comprar um notebook e gostaria de ver os modelos disponíveis.',
	);
---

<section class="hero" aria-labelledby="hero-title">
	<div class="container-site hero-inner">
		<div class="hero-content">
			<h1 id="hero-title" class="hero-title">
				Notebooks seminovos de alta qualidade com Nota Fiscal, Garantia e Entrega em Domicílio, em até
				12x no cartão
			</h1>
			<p class="hero-subtitle">
				Há mais de 30 anos oferecendo produtos de qualidade por valores justos e acessíveis. As
				melhores marcas e modelos por até 50% do valor de mercado!
			</p>
			<div class="hero-actions">
				<a
					class="btn-primary hero-cta"
					href={heroWhatsappUrl}
					target="_blank"
					rel="noopener noreferrer"
				>
					Confira os modelos disponíveis
					<span class="btn-icon" aria-hidden="true" set:html={whatsappIcon} />
				</a>
				<a class="hero-secondary" href="#modelos">Saiba mais ↓</a>
			</div>
		</div>
		<div class="hero-media">
			<HeroVideoFacade />
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		padding: 2.5rem 0 3.5rem;
		background: linear-gradient(
			180deg,
			#3d9be8 0%,
			#5eb3ef 42%,
			#8ecbf5 78%,
			#b5dff9 100%
		);
	}

	.hero::before {
		content: '';
		position: absolute;
		inset: 0 auto 0 0;
		width: 5px;
		background: #2076c9;
		display: none;
	}

	.hero-media {
		display: none;
	}

	.hero-inner {
		display: grid;
		gap: 2rem;
		align-items: center;
	}

	.hero-title {
		font-size: clamp(1.75rem, 7vw, 3rem);
		line-height: 1.2;
		max-width: 36rem;
		color: #fff;
	}

	.hero-subtitle {
		margin-top: 1.25rem;
		max-width: 34rem;
		font-size: clamp(0.975rem, 2.5vw, 1.125rem);
		line-height: 1.7;
		color: rgb(255 255 255 / 0.92);
	}

	.hero-actions {
		margin-top: 1.75rem;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 0.875rem;
	}

	.hero-cta {
		width: 100%;
		padding: 0.875rem 1.25rem;
	}

	.btn-icon :global(svg) {
		display: block;
		width: 1.125rem;
		height: 1.125rem;
		flex-shrink: 0;
	}

	.btn-icon :global(svg title) {
		display: none;
	}

	.hero-secondary {
		color: #d8f1ff;
		font-weight: 600;
		text-decoration: none;
		padding: 0.25rem;
		text-align: center;
	}

	.hero-secondary:hover {
		color: #fff;
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	@media (min-width: 48rem) {
		.hero {
			padding: 4rem 0 5rem;
			background: linear-gradient(
				90deg,
				#3d9be8 0%,
				#5eb3ef 38%,
				#8ecbf5 72%,
				#b5dff9 100%
			);
		}

		.hero::before {
			display: block;
		}

		.hero-media {
			display: block;
		}

		.hero-inner {
			grid-template-columns: 1fr 1fr;
			gap: 2.5rem;
		}

		.hero-title {
			line-height: 1.15;
		}

		.hero-actions {
			flex-direction: row;
			flex-wrap: wrap;
			align-items: center;
			margin-top: 2rem;
		}

		.hero-cta {
			width: auto;
		}

		.hero-secondary {
			text-align: left;
		}
	}
</style>
