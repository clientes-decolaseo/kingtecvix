---
import { getImage, Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_NAME } from '../../consts';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');

	return Promise.all(
		posts.map(async (post) => ({
			params: { slug: post.id },
			props: { post },
		})),
	);
}

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, coverImage, coverImageAlt } = post.data;
const { Content } = await render(post);

const ogImage = (
	await getImage({
		src: coverImage,
		width: 1200,
		height: 630,
		format: 'webp',
		quality: 80,
	})
).src;

const pageTitle = `${title} | Blog ${SITE_NAME}`;
const formattedDate = pubDate.toLocaleDateString('pt-BR', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});

const whatsappUrl =
	'https://wa.me/5527997441969?text=' +
	encodeURIComponent(
		`Olá! Li o artigo "${title}" no blog e gostaria de saber mais sobre notebooks seminovos.`,
	);

const blogPostingSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	datePublished: pubDate.toISOString(),
	description,
	author: {
		'@type': 'Organization',
		name: SITE_NAME,
	},
};
---

<Layout title={pageTitle} description={description} ogImage={ogImage}>
	<script slot="head" type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
	<Header />
	<main class="blog-post-page">
		<div class="container-site blog-post-content">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<ol>
					<li><a href="/">Home</a></li>
					<li><a href="/blog">Blog</a></li>
					<li aria-current="page">{title}</li>
				</ol>
			</nav>

			<article>
				<header class="blog-post-header">
					<Image
						src={coverImage}
						alt={coverImageAlt}
						width={1200}
						height={630}
						format="webp"
						quality={80}
						loading="eager"
						fetchpriority="high"
						class="blog-post-cover"
					/>
					<h1>{title}</h1>
					<time datetime={pubDate.toISOString()}>{formattedDate}</time>
				</header>

				<div class="blog-prose">
					<Content />
				</div>

				<aside class="blog-post-cta">
					<p>Quer ajuda para escolher o notebook seminovo ideal? Fale com a equipe KingTecVix.</p>
					<a class="btn-primary" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
						Fale no WhatsApp
					</a>
				</aside>
			</article>
		</div>
	</main>
	<Footer />
</Layout>

<style>
	.blog-post-page {
		padding: 4rem 0 5rem;
	}

	.blog-post-content {
		max-width: 45rem;
	}

	.breadcrumb ol {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
		margin: 0 0 1.5rem;
		padding: 0;
		font-size: 0.875rem;
		color: color-mix(in srgb, var(--color-text) 70%, white);
	}

	.breadcrumb li + li::before {
		content: '>';
		margin-right: 0.5rem;
	}

	.breadcrumb a {
		color: var(--color-text);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.breadcrumb a:hover {
		color: var(--color-accent-text);
	}

	.blog-post-header h1 {
		font-size: clamp(1.75rem, 4vw, 2.25rem);
		line-height: 1.2;
		color: var(--color-text);
		margin: 1.25rem 0 0.5rem;
	}

	.blog-post-cover {
		width: 100%;
		height: auto;
		aspect-ratio: 1200 / 630;
		object-fit: cover;
		border-radius: 1rem;
	}

	.blog-post-header time {
		display: block;
		margin-bottom: 2rem;
		font-size: 0.9rem;
		color: color-mix(in srgb, var(--color-text) 70%, white);
	}

	.blog-prose :global(p) {
		margin: 0 0 1rem;
		line-height: 1.7;
		color: color-mix(in srgb, var(--color-text) 90%, white);
	}

	.blog-prose :global(h2) {
		font-size: 1.25rem;
		margin: 2rem 0 0.75rem;
		color: var(--color-text);
	}

	.blog-prose :global(ul) {
		margin: 0 0 1rem 1.25rem;
		padding: 0;
		line-height: 1.7;
		color: color-mix(in srgb, var(--color-text) 90%, white);
	}

	.blog-prose :global(a) {
		color: var(--color-text);
		font-weight: 600;
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.blog-prose :global(a:hover) {
		color: var(--color-accent-text);
	}

	.blog-post-cta {
		margin-top: 2.5rem;
		padding: 1.5rem;
		border: 1px solid #e2e8f0;
		border-radius: 1rem;
		background: #f8fbff;
	}

	.blog-post-cta p {
		margin: 0 0 1rem;
		line-height: 1.7;
		color: color-mix(in srgb, var(--color-text) 90%, white);
	}
</style>
