---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_NAME } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const pageTitle = `Blog | ${SITE_NAME}`;
const pageDescription =
	'Dicas, novidades e conteúdos sobre notebooks seminovos, manutenção e compra inteligente.';
---

<Layout title={pageTitle} description={pageDescription}>
	<Header />
	<main class="blog-page">
		<div class="container-site">
			<h1>Blog KingTecVix</h1>

			{
				posts.length > 0 ? (
					<ul class="blog-list">
						{posts.map((post) => (
							<li>
								<article class="blog-card">
									<time datetime={post.data.pubDate.toISOString()}>
										{post.data.pubDate.toLocaleDateString('pt-BR', {
											day: 'numeric',
											month: 'long',
											year: 'numeric',
										})}
									</time>
									<h2>
										<a href={`/blog/${post.id}`}>{post.data.title}</a>
									</h2>
									<p>{post.data.description}</p>
									<a class="blog-card-link" href={`/blog/${post.id}`}>
										Ler artigo
									</a>
								</article>
							</li>
						))}
					</ul>
				) : (
					<p class="blog-empty">Nenhum artigo publicado ainda. Volte em breve.</p>
				)
			}
		</div>
	</main>
	<Footer />
</Layout>

<style>
	.blog-page {
		padding: 4rem 0 5rem;
	}

	.blog-page h1 {
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		line-height: 1.2;
		color: var(--color-text);
		margin-bottom: 2rem;
	}

	.blog-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1.5rem;
	}

	.blog-card {
		padding: 1.5rem;
		border: 1px solid #e2e8f0;
		border-radius: 1rem;
		background: var(--color-background);
		box-shadow: 0 8px 24px rgb(16 33 104 / 6%);
	}

	.blog-card time {
		display: block;
		margin-bottom: 0.5rem;
		font-size: 0.875rem;
		color: color-mix(in srgb, var(--color-text) 70%, white);
	}

	.blog-card h2 {
		font-size: 1.35rem;
		margin: 0 0 0.75rem;
	}

	.blog-card h2 a {
		color: var(--color-text);
		text-decoration: none;
	}

	.blog-card h2 a:hover {
		color: var(--color-accent-text);
	}

	.blog-card p {
		margin: 0 0 1rem;
		line-height: 1.7;
		color: color-mix(in srgb, var(--color-text) 85%, white);
	}

	.blog-card-link {
		font-weight: 600;
		color: var(--color-accent-text);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.blog-empty {
		line-height: 1.7;
		color: color-mix(in srgb, var(--color-text) 80%, white);
	}
</style>
