---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import { SITE_NAME } from '../consts';

interface Props {
	title: string;
	description: string;
	ogImage?: string;
}

const { title, description, ogImage = '/og-image.png' } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
const logoURL = new URL('/logo-og.png', Astro.site);
const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'Organization',
	name: `${SITE_NAME} Comércio de Informática LTDA`,
	alternateName: SITE_NAME,
	url: 'https://kingtecvix.com.br',
	logo: logoURL.href,
	taxID: '62.658.277/0001-63',
	telephone: '+5527997441969',
	areaServed: [
		{ '@type': 'City', name: 'Vitória' },
		{ '@type': 'City', name: 'Vila Velha' },
		{ '@type': 'City', name: 'Cariacica' },
		{ '@type': 'City', name: 'Serra' },
		{ '@type': 'City', name: 'Viana' },
		{ '@type': 'City', name: 'Guarapari' },
		{ '@type': 'City', name: 'Aracruz' },
		{ '@type': 'City', name: 'Santa Tereza' },
		{ '@type': 'City', name: 'Domingos Martins' },
		{ '@type': 'City', name: 'Fundão' },
		{ '@type': 'City', name: 'Ibiraçu' },
		{ '@type': 'City', name: 'Santa Leopoldina' },
	],
	contactPoint: {
		'@type': 'ContactPoint',
		telephone: '+5527997441969',
		contactType: 'sales',
		areaServed: 'BR',
		availableLanguage: 'Portuguese',
	},
};
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<!-- Google Tag Manager (carregado apenas com consentimento) -->
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			window.loadGTM = function () {
				if (window._gtmLoaded) return;
				window._gtmLoaded = true;
				window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
				var script = document.createElement('script');
				script.async = true;
				script.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-TFH8DZC3';
				document.head.appendChild(script);
			};
		</script>
		<!-- End Google Tag Manager -->

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="preload" href="/fonts/poppins-400.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/poppins-600.woff2" as="font" type="font/woff2" crossorigin />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="pt_BR" />
		<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
		<slot name="head" />
	</head>
	<body>
		<slot />
		<FloatingWhatsApp />
		<CookieConsent />
	</body>
</html>
