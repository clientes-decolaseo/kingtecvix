---
import '../styles/global.css';
import { Image } from 'astro:assets';
import CookieConsent from '../components/CookieConsent.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import { getCollection } from 'astro:content';
import logo from '../assets/logo.png';
import { SITE_NAME } from '../consts';

interface Props {
	title: string;
	description: string;
	ogImage?: string;
}

const { title, description, ogImage = '/og-image.png' } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
const logoURL = new URL('/logo-og.png', Astro.site);

const testimonials = (await getCollection('testimonials')).sort(
	(a, b) => a.data.order - b.data.order,
);

const organizationSchema = {
	'@context': 'https://schema.org',
	'@type': 'ElectronicsStore',
	name: `${SITE_NAME} Comércio de Informática LTDA`,
	alternateName: SITE_NAME,
	url: 'https://kingtecvix.com.br',
	logo: logoURL.href,
	taxID: '62.658.277/0001-63',
	telephone: '+5527997441969',
	sameAs: ['https://share.google/R9buVGjbEVxnDkspS'],
	areaServed: [
		{ '@type': 'City', name: 'Vitória' },
		{ '@type': 'City', name: 'Vila Velha' },
		{ '@type': 'City', name: 'Cariacica' },
		{ '@type': 'City', name: 'Serra' },
		{ '@type': 'City', name: 'Viana' },
		{ '@type': 'City', name: 'Guarapari' },
		{ '@type': 'City', name: 'Aracruz' },
		{ '@type': 'City', name: 'Santa Tereza' },
		{ '@type': 'City', name: 'Domingos Martins' },
		{ '@type': 'City', name: 'Fundão' },
		{ '@type': 'City', name: 'Ibiraçu' },
		{ '@type': 'City', name: 'Santa Leopoldina' },
	],
	contactPoint: {
		'@type': 'ContactPoint',
		telephone: '+5527997441969',
		contactType: 'sales',
		areaServed: 'BR',
		availableLanguage: 'Portuguese',
	},
	aggregateRating: {
		'@type': 'AggregateRating',
		ratingValue: '4.9',
		bestRating: '5',
		reviewCount: '57',
	},
	review: testimonials.map((testimonial) => ({
		'@type': 'Review',
		author: {
			'@type': 'Person',
			name: testimonial.data.name,
		},
		reviewRating: {
			'@type': 'Rating',
			ratingValue: String(testimonial.data.rating),
			bestRating: '5',
		},
		reviewBody: testimonial.data.text,
	})),
};
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<!-- Google Tag Manager (carregado apenas com consentimento) -->
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			window.loadGTM = function () {
				if (window._gtmLoaded) return;
				window._gtmLoaded = true;
				window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
				var script = document.createElement('script');
				script.async = true;
				script.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-TFH8DZC3';
				document.head.appendChild(script);
			};
		</script>
		<!-- End Google Tag Manager -->

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="preload" href="/fonts/poppins-400.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/poppins-600.woff2" as="font" type="font/woff2" crossorigin />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="pt_BR" />
		<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
		<slot name="head" />
	</head>
	<body>
		<header class="landing-topbar">
			<div class="container-site landing-topbar-inner">
				<span class="landing-logo" aria-label={`${SITE_NAME} — notebooks seminovos`}>
					<Image
						src={logo}
						alt={`Logo ${SITE_NAME}`}
						width={300}
						height={120}
						format="webp"
						quality="mid"
						loading="eager"
						class="landing-logo-image"
					/>
				</span>
			</div>
		</header>

		<slot />

		<footer class="landing-footer">
			<div class="container-site landing-footer-inner">
				<p class="landing-footer-copy">
					2026 © KINGTECVIX COMERCIO DE INFORMATICA LTDA. CNPJ 62.658.277/0001-63. Todos os direitos
					reservados
				</p>
				<p class="landing-footer-privacy">
					<a href="/politica-privacidade">Política de Privacidade</a>
				</p>
			</div>
		</footer>

		<FloatingWhatsApp />
		<CookieConsent />
	</body>
</html>

<style>
	.landing-topbar {
		border-bottom: 1px solid #e2e8f0;
		background: var(--color-background);
	}

	.landing-topbar-inner {
		display: flex;
		align-items: center;
		padding-block: 0.875rem;
	}

	.landing-logo {
		display: inline-block;
		line-height: 0;
	}

	.landing-logo-image {
		width: 8.75rem;
		height: auto;
	}

	@media (min-width: 768px) {
		.landing-logo-image {
			width: 12.5rem;
		}
	}

	.landing-footer {
		padding: 2rem 0;
		border-top: 1px solid #e2e8f0;
		background: #f8fbff;
	}

	.landing-footer-inner {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		align-items: flex-start;
	}

	.landing-footer-copy {
		margin: 0;
		line-height: 1.6;
		font-size: 0.95rem;
		color: color-mix(in srgb, var(--color-text) 80%, white);
	}

	.landing-footer-privacy {
		margin: 0;
		font-size: 0.85rem;
	}

	.landing-footer-privacy a {
		color: color-mix(in srgb, var(--color-text) 65%, white);
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	.landing-footer-privacy a:hover {
		color: var(--color-accent-text);
	}

	@media (min-width: 768px) {
		.landing-footer-inner {
			flex-direction: row;
			align-items: center;
			justify-content: space-between;
		}
	}
</style>
